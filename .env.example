# Battery Brain — Environment Variable Template
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# ─── Security ────────────────────────────────────────────────────────────────
# Bearer token for REST API and WebSocket authentication
API_KEY=changeme-generate-a-secure-key

# ─── Database ────────────────────────────────────────────────────────────────
DB_PATH=/app/data/battery_brain.db

# ─── FoxESS Cloud API ────────────────────────────────────────────────────────
# Get these from: https://www.foxesscloud.com/user/center (API section)
FOXESS_API_KEY=
FOXESS_TOKEN=
FOXESS_DEVICE_SN=

# ─── Amber Electric API ──────────────────────────────────────────────────────
# Get your API key from: https://app.amber.com.au/developers
AMBER_API_KEY=
# Your site ID — run: python -c "import amberelectric; ..." or check Amber dashboard
AMBER_SITE_ID=

# ─── Site Location (for Open-Meteo solar forecast) ───────────────────────────
SITE_LATITUDE=-27.47
SITE_LONGITUDE=153.02

# ─── PV System ───────────────────────────────────────────────────────────────
PANEL_CAPACITY_W=6600
PANEL_EFFICIENCY=0.80

# ─── Battery Config ───────────────────────────────────────────────────────────
BAT_CAPACITY_KWH=10.0
BAT_MIN_SOC=20
BAT_MAX_SOC=95

# ─── Polling Intervals ────────────────────────────────────────────────────────
# FoxESS telemetry: min 120s per ADR-008 rate limit strategy
FOXESS_POLL_INTERVAL_SEC=180
AMBER_POLL_INTERVAL_SEC=300
SOLAR_POLL_INTERVAL_SEC=3600
DECISION_ENGINE_INTERVAL_SEC=900

# ─── Application ─────────────────────────────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=info
VERSION=1.0.0
